# ──────────────────────────────────────────────
# Palletizing Simulator Configuration
# ──────────────────────────────────────────────

# Isaac Sim 앱 설정
app:
  experience: "/isaac-sim/apps/isaacsim.exp.full.streaming.kit"
  width: 1920
  height: 1080
  headless: true
  hide_ui: false
  renderer: "RayTracedLighting"
  display_options: 3286
  extensions:
    - omni.kit.livestream.webrtc
    - omni.kit.window.script_editor
    - omni.graph.ui
    - omni.graph.core
    - omni.graph.window.action

runtime:
  auto_start: true

# 경로 설정
paths:
  # 참가자 알고리즘 실행 결과 JSON이 저장된 폴더
  input_dir: "/isaac-sim/palletizing_simulator/algorithm_results"

  # 알고리즘 실행에 사용한 입력 박스 시퀀스 폴더
  box_sequence_dir: "/isaac-sim/palletizing_simulator/box_sequence"

  # Isaac Sim 시뮬레이션 결과가 저장될 폴더
  output_dir: "/isaac-sim/palletizing_simulator/sim_results"

pallet:
  size: [1.2, 1.0, 1.25]

# 박스 안착 제어
settling:
  max_steps: 10           # 박스 1개당 최대 안착 스텝
  min_frames: 5          # 최소 대기 프레임 (early-exit 방지)
  velocity_threshold: 0.05  # 안착 판정 속도 (m/s)
  final_steps: 100        # 전체 적재 완료 후 추가 안정화 스텝
  drop_offset: 0.02       # 박스 스폰 높이 오프셋 (m)


# 물리 재질
physics:
  box:
    static_friction: 0.6
    dynamic_friction: 0.5
    restitution: 0.0
    linear_damping: 3.0
    angular_damping: 6.0
    contact_offset: 0.003
    rest_offset: 0.0
  ground:
    static_friction: 0.7
    dynamic_friction: 0.5
    restitution: 0.0
  pallet:
    thickness: 0.15
    color: [0.55, 0.35, 0.15]
    static_friction: 0.7
    dynamic_friction: 0.5
    restitution: 0.0
    contact_offset: 0.003
    rest_offset: 0.0

# 버퍼 영역 (팔레트 우측에 배치)
buffer:
  gap_from_pallet: 0.30      # 팔레트 우측 간격 (m)
  slot_size: [0.55, 0.55]    # 슬롯 크기 [width, depth] (m)
  slots_per_row: 5            # 행당 슬롯 수
  platform_thickness: 0.05    # 버퍼 플랫폼 두께 (m)
  color: [0.40, 0.40, 0.65]  # 버퍼 플랫폼 색상 (보라색 계열)

# 층별 박스 색상 (RGB, 0~1)
colors:
  layer_height: 0.25      # 층 판별 기준 높이 (m)
  layers:
    - [0.20, 0.80, 0.20]  # 1층 – green
    - [0.20, 0.50, 0.90]  # 2층 – blue
    - [0.90, 0.45, 0.10]  # 3층 – orange
    - [0.85, 0.20, 0.20]  # 4층+ – red

# 적재 결과 평가 기준
evaluation:
  # 의도 위치(input JSON, 팔레트 상면 기준) vs 최종 위치(월드 기준) 차이
  drift_threshold_m: 0.40     # drift 이상이면 박스 실패 (m) – 물리 오차 감안
  bounds_tolerance_m: 0.02    # 팔레트 경계 여유 (m)
  # 에피소드(파일 1개) 성공 판정 기준
  episode_success_min_rate: 1.00  # 박스 성공률 100% 이상이면 에피소드 성공

# 스크린샷 설정
screenshot:
  width: 1920
  height: 1080
  # 팔레트 중심 기준 카메라 오프셋 (x, y, z)
  camera_offset: [-3.0, -3.0, 3.5]
  look_at_z: 0.5
  rt_subframes: 8         # 광선 추적 품질
  flush_frames: 4         # 렌더 안정화 프레임
